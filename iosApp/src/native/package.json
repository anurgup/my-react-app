{
  "name": "textrefine-native",
  "version": "1.0.0",
  "description": "React Native version of TextRefine - Polish your messages before you send",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "build-android": "cd android && ./gradlew assembleRelease",
    "build-ios": "cd ios && xcodebuild -configuration Release"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-native": "^0.74.0",
    "@react-native-picker/picker": "^2.6.1",
