# API Configuration
REACT_APP_API_BASE_URL=https://api.example.com

# Feature Flags
ENABLE_TEXT_REFINEMENT=true
ENABLE_RESPONSE_GENERATION=true
MAX_CHAT_MESSAGES=10

# Language Settings
DEFAULT_LANGUAGE=english
SUPPORTED_LANGUAGES=english,hindi,spanish,french,german,portuguese,italian,japanese,korean,chinese

# UI Settings
THEME=light
